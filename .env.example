OPENAI_API_KEY=sk-...
# Optional: unauthenticated Semantic Scholar calls work at a low rate limit.
# Add a free key from https://www.semanticscholar.org/product/api to raise it.
SEMANTIC_SCHOLAR_API_KEY=
# Optional: required for the Unpaywall half of abstract recovery
# (research_agent/enrichment.py). Unpaywall's terms require a real, working
# contact email on every request and rejects placeholder addresses — without
# this set, that source is skipped and enrichment falls through to CrossRef
# only. See https://unpaywall.org/products/api
UNPAYWALL_EMAIL=
# Optional: enables the web-context section (research_agent/web_search.py).
# Get a free key at https://tavily.com. Without this set, search degrades to
# paper-only results.
TAVILY_API_KEY=
